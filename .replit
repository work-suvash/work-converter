modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
build = ["bun", "run", "build"]
publicDir = "build"

[userenv]

[userenv.shared]
PUB_ENV = "development"
PUB_DISABLE_FAILURE_BLOCKS = "false"
PUB_DISABLE_ALL_EXTERNAL_REQUESTS = "false"
PUB_VERTD_URL = "https://vertd.vert.sh"
PUB_PLAUSIBLE_URL = ""
PUB_HOSTNAME = ""
PUB_DONATION_URL = ""
PUB_STRIPE_KEY = ""
